    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
